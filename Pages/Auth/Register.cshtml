@page
@model InventoryApp.Pages.Auth.RegisterModel
@using Microsoft.Extensions.Localization
@using InventoryApp
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Register"];
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                <h3 class="text-center mb-4">
                    <i class="bi bi-person-plus"></i> @Localizer["Register"]
                </h3>

                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label"></label>
                        <input asp-for="Input.Name" class="form-control" autocomplete="name" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.Password" type="password" class="form-control"
                                   id="registerPasswordInput" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('registerPasswordInput', this)"
                                    aria-label="@Localizer["PasswordToggleAria"]">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <div class="form-text">@Localizer["Min6Chars"]</div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-person-check me-1"></i> @Localizer["CreateAccount"]
                    </button>
                </form>

                @if (Model.ExternalProviders.Count > 0)
                {
                    <hr class="my-4" />
                    <p class="text-center text-muted small mb-3">@Localizer["OrSignInWith"]</p>
                    <div class="d-grid gap-2">
                        @foreach (var provider in Model.ExternalProviders)
                        {
                            <form method="post" asp-page-handler="ExternalLogin">
                                <input type="hidden" name="provider" value="@provider.Name" />
                                <button type="submit" class="btn btn-outline-secondary w-100">
                                    @if (provider.Name == "Google")
                                    {
                                        <i class="bi bi-google me-2"></i>
                                    }
                                    else if (provider.Name == "GitHub")
                                    {
                                        <i class="bi bi-github me-2"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-box-arrow-in-right me-2"></i>
                                    }
                                    @Localizer["ContinueWith"] @provider.DisplayName
                                </button>
                            </form>
                        }
                    </div>
                }

                <div class="text-center mt-3">
                    <small>
                        @Localizer["AlreadyHaveAccount"]
                        <a asp-page="/Auth/Login">@Localizer["SignIn"]</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            btn.querySelector('i').className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
    </script>
}