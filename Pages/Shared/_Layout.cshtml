<!DOCTYPE html>
<html lang="en" data-bs-theme="@(User.FindFirst("Theme")?.Value ?? "light")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvenTrack</title>
    <meta name="description" content="InvenTrack — flexible inventory management for teams." />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg shadow-sm" id="mainNav">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    <i class="bi bi-boxes me-1"></i> InvenTrack
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- Global search (every page, spec requirement) -->
                    <form class="d-flex mx-auto" method="get" asp-page="/Search" role="search">
                        <div class="input-group" style="min-width:240px">
                            <input type="search" name="q" class="form-control form-control-sm"
                                   placeholder="Search inventories…"
                                   value="@(Context.Request.Query["q"].ToString())"
                                   aria-label="Global search" />
                            <button class="btn btn-outline-secondary btn-sm" type="submit"
                                    aria-label="Search">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Inventories/Index">
                                <i class="bi bi-boxes me-1"></i>Inventories
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.FindFirst("IsAdmin")?.Value == "true")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Admin/Users">
                                        <i class="bi bi-shield-lock me-1"></i> Admin
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Users/Index">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @(User.FindFirst("DisplayName")?.Value ?? User.Identity.Name)
                                </a>
                            </li>

                            <!-- Theme toggle -->
                            <li class="nav-item">
                                <form method="post" asp-page="/Api/Preferences" asp-page-handler="Theme">
                                    @{
                                        var currentTheme = User.FindFirst("Theme")?.Value ?? "light";
                                    }
                                    <input type="hidden" name="theme"
                                           value="@(currentTheme == "light" ? "dark" : "light")" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary border-0"
                                            title="Toggle theme" aria-label="Toggle dark/light theme">
                                        <i class="bi @(currentTheme == "dark" ? "bi-sun" : "bi-moon")"></i>
                                    </button>
                                </form>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-page="/Auth/Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/Register">
                                    <i class="bi bi-person-plus me-1"></i> Register
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="text-center text-muted py-3 small border-top mt-4">
        © 2026 InvenTrack
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>