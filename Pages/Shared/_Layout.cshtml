@using Microsoft.Extensions.Localization
@using InventoryApp
@inject IStringLocalizer<SharedResource> Localizer
<!DOCTYPE html>
<html lang="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName)" data-bs-theme="@(User.FindFirst("Theme")?.Value ?? "light")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvenTrack</title>
    <meta name="description" content="InvenTrack — flexible inventory management for teams." />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg shadow-sm" id="mainNav">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    <i class="bi bi-boxes me-1"></i> InvenTrack
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- Global search (every page, spec requirement) -->
                    <form class="d-flex mx-auto" method="get" asp-page="/Inventories/Index" role="search">
                        <div class="input-group" style="min-width:240px">
                            <input type="search" name="q" class="form-control form-control-sm"
                                   placeholder="@Localizer["Search"]..."
                                   value="@(Context.Request.Query["q"].ToString())"
                                   aria-label="Global search" />
                            <button class="btn btn-outline-secondary btn-sm" type="submit"
                                    aria-label="Search">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Inventories/Index">
                                <i class="bi bi-boxes me-1"></i>@Localizer["Inventories"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <!-- Theme toggle -->
                            @{
                                var currentTheme = User.FindFirst("Theme")?.Value ?? "light";
                            }
                            <button type="button" id="themeToggleBtn"
                                    class="btn btn-sm btn-outline-secondary border-0 mt-1"
                                    title="Toggle theme" aria-label="Toggle dark/light theme">
                                <i id="themeToggleIcon" class="bi @(currentTheme == "dark" ? "bi-sun" : "bi-moon")"></i>
                            </button>
                            <!-- Form needed just to generate the AntiForgery token for our JS -->
                            <form id="themeForm" method="post" asp-page="/Api/Preferences" asp-page-handler="Theme" style="display:none;">
                                <input type="hidden" name="theme" id="themeInput" value="" />
                            </form>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle btn btn-sm btn-outline-secondary border-0" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate me-1"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li>
                                    <a class="dropdown-item @(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "en" ? "active" : "")" 
                                       asp-page="/SetLanguage" asp-route-culture="en" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString">
                                        English
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item @(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "ru" ? "active" : "")" 
                                       asp-page="/SetLanguage" asp-route-culture="ru" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString">
                                        Русский
                                    </a>
                                </li>
                            </ul>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.FindFirst("IsAdmin")?.Value == "true")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Admin/Users">
                                        <i class="bi bi-shield-lock me-1"></i> @Localizer["Admin"]
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Users/Index">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @(User.FindFirst("DisplayName")?.Value ?? User.Identity.Name)
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-page="/Auth/Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> @Localizer["Logout"]
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> @Localizer["Login"]
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/Register">
                                    <i class="bi bi-person-plus me-1"></i> @Localizer["Register"]
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="text-center text-muted py-3 small border-top mt-4 gap-3 d-flex justify-content-center align-items-center flex-wrap">
        <span>© 2026 InvenTrack</span>
        &bull;
        <a href="#" class="text-decoration-none text-primary" data-bs-toggle="modal" data-bs-target="#supportTicketModal" onclick="prepareSupportTicket()">
            <i class="bi bi-life-preserver me-1"></i>Create support ticket
        </a>
    </footer>

    <!-- Support Ticket Modal -->
    <div class="modal fade" id="supportTicketModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-headset me-2"></i>Create Support Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="ticketAlert" class="alert d-none"></div>
                    <form id="supportTicketForm">
                        <input type="hidden" id="ticketLink" name="Link" />
                        <input type="hidden" id="ticketInventoryTitle" name="InventoryTitle" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Summary</label>
                            <textarea class="form-control" name="Summary" id="ticketSummary" rows="3" required placeholder="Describe your issue..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Priority</label>
                            <select class="form-select" name="Priority" id="ticketPriority">
                                <option value="Low">Low</option>
                                <option value="Average" selected>Average</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="btnSubmitTicket" onclick="submitSupportTicket()">
                        Submit Ticket
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function prepareSupportTicket() {
            document.getElementById('ticketLink').value = window.location.href;
            
            // Try to extract the inventory title from the breadcrumb if available
            var activeBreadcrumb = document.querySelector('.breadcrumb-item.active');
            var inventoryTitle = activeBreadcrumb ? activeBreadcrumb.textContent.trim() : "";
            document.getElementById('ticketInventoryTitle').value = inventoryTitle;
            
            document.getElementById('ticketSummary').value = "";
            document.getElementById('ticketPriority').value = "Average";
            document.getElementById('ticketAlert').className = "alert d-none";
            document.getElementById('btnSubmitTicket').disabled = false;
        }

        async function submitSupportTicket() {
            const btn = document.getElementById('btnSubmitTicket');
            const alertBox = document.getElementById('ticketAlert');
            const form = document.getElementById('supportTicketForm');
            
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';
            alertBox.className = "alert d-none";

            try {
                const formData = new FormData(form);
                const response = await fetch('/Support/Ticket', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alertBox.textContent = "Ticket submitted successfully! Support staff will review it soon.";
                    alertBox.className = "alert alert-success mt-2";
                    form.reset();
                    setTimeout(() => {
                        const modalEl = document.getElementById('supportTicketModal');
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        if(modal) modal.hide();
                    }, 2500);
                } else {
                    alertBox.textContent = result.message || "Failed to submit ticket.";
                    alertBox.className = "alert alert-danger mt-2";
                    btn.disabled = false;
                    btn.textContent = "Submit Ticket";
                }
            } catch (err) {
                alertBox.textContent = "Network error. Please try again.";
                alertBox.className = "alert alert-danger mt-2";
                btn.disabled = false;
                btn.textContent = "Submit Ticket";
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('themeToggleBtn');
            const icon = document.getElementById('themeToggleIcon');
            const htmlTag = document.documentElement;
            const themeForm = document.getElementById('themeForm');
            const themeInput = document.getElementById('themeInput');

            // Override with localStorage if it exists so we immediately sync UI
            const storedTheme = localStorage.getItem('theme');
            if (storedTheme) {
                htmlTag.setAttribute('data-bs-theme', storedTheme);
                icon.className = storedTheme === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
            }

            if (toggleBtn) {
                toggleBtn.addEventListener('click', async () => {
                    const currentTheme = htmlTag.getAttribute('data-bs-theme');
                    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

                    // 1. Update UI Instantly
                    htmlTag.setAttribute('data-bs-theme', newTheme);
                    icon.className = newTheme === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
                    localStorage.setItem('theme', newTheme);

                    // 2. Sync to Server in background
                    if (themeForm) {
                        themeInput.value = newTheme;
                        const formData = new FormData(themeForm);
                        try {
                            await fetch(themeForm.action, {
                                method: 'POST',
                                body: formData
                            });
                        } catch (e) { console.error('Failed to sync theme to server', e); }
                    }
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>