@using InventoryApp.Models
@model CustomIdElement

<div class="badge bg-primary element-chip d-flex align-items-center gap-1 p-2 fs-6"
     data-type="@((int)Model.ElementType)"
     data-type-name="@Model.ElementType"
     data-config='@Model.Config'>
    <i class="bi bi-grip-horizontal"></i>
    <span>@Model.ElementType</span>
    @if (Model.ElementType == IdElementType.FixedText)
    {
        var cfg = System.Text.Json.JsonDocument.Parse(Model.Config).RootElement;
        var text = cfg.TryGetProperty("text", out var v) ? v.GetString() : "";
        <input class="form-control form-control-sm ms-1" style="width:80px;color:#000"
               value="@text" readonly />
    }
    <button type="button" class="btn-close btn-close-white ms-1" disabled></button>
</div>
