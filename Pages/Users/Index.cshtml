@page
@model InventoryApp.Pages.Users.IndexModel
@using Microsoft.Extensions.Localization
@using InventoryApp
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Profile"] + " — " + Model.ProfileUser?.Name;
    var u = Model.ProfileUser;
    var isAdmin   = u?.IsAdmin == true;
    var isBlocked = u?.LockoutEnd.HasValue == true && u.LockoutEnd > DateTimeOffset.UtcNow;
    var isMe = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == u?.Id.ToString();
}

<!-- Profile header -->
<div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fs-2 fw-bold flex-shrink-0"
         style="width:64px;height:64px">
        @(u?.Name?.Length > 0 ? u.Name[0].ToString().ToUpper() : "?")
    </div>
    <div>
        <h2 class="mb-1 fw-bold">@u?.Name</h2>
        <div class="text-muted small mb-2">@u?.Email</div>
        <div class="d-flex gap-2 flex-wrap">
            @if (isAdmin)
            {
                <span class="badge bg-warning text-dark"><i class="bi bi-shield-fill me-1"></i>@Localizer["Admin"]</span>
            }
            else
            {
                <span class="badge bg-primary"><i class="bi bi-person-fill me-1"></i>@Localizer["Member"]</span>
            }
            @if (isBlocked)
            {
                <span class="badge bg-danger"><i class="bi bi-lock-fill me-1"></i>@Localizer["Blocked"]</span>
            }
            else
            {
                <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>@Localizer["Active"]</span>
            }
        </div>
    </div>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="text-muted small mb-1">@Localizer["MemberSince"]</div>
                <div class="fw-semibold">@u?.RegisteredAt.ToString("D", System.Globalization.CultureInfo.CurrentCulture)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="text-muted small mb-1">@Localizer["LastLogin"]</div>
                <div class="fw-semibold">@(u?.LastLoginAt?.ToString("g", System.Globalization.CultureInfo.CurrentCulture) ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="text-muted small mb-1">@Localizer["InventoriesOwned"]</div>
                <div class="fw-semibold fs-4">@Model.OwnedInvs.Count</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="text-muted small mb-1">@Localizer["ThemeLanguage"]</div>
                <div class="fw-semibold">
                    @(u?.ThemePreference == "dark" ? "🌙 Dark" : "☀️ Light")
                    &nbsp;·&nbsp;
                    @(u?.LanguagePreference?.ToUpper() ?? "EN")
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sync to Salesforce CRM (only for self or admin) -->
@if (isMe || User.FindFirst("IsAdmin")?.Value == "true")
{
    <div class="d-flex justify-content-end mb-4">
        <button class="btn btn-outline-primary btn-sm"
                data-bs-toggle="modal"
                data-bs-target="#sfModal"
                id="sfBtn">
            <i class="bi bi-cloud-upload me-1"></i>Sync to Salesforce CRM
        </button>
    </div>

    <!-- Salesforce Modal -->
    <div class="modal fade" id="sfModal" tabindex="-1" aria-labelledby="sfModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="sfModalLabel">
                        <i class="bi bi-cloud-upload me-2 text-primary"></i>Create Salesforce Account &amp; Contact
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="sfAlert" class="alert d-none"></div>
                    <form id="sfForm">
                        <h6 class="text-muted fw-semibold mb-3">Account (Company)</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="form-label">Company Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="companyName" id="sfCompany" required placeholder="e.g. Acme Corp">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone</label>
                                <input type="text" class="form-control" name="phone" placeholder="+1 555 0100">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Website</label>
                                <input type="url" class="form-control" name="website" placeholder="https://example.com">
                            </div>
                        </div>
                        <h6 class="text-muted fw-semibold mb-3">Contact (Person)</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" name="firstName" id="sfFirstName">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="lastName" id="sfLastName" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" id="sfEmail">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Job Title</label>
                                <input type="text" class="form-control" name="jobTitle" placeholder="e.g. Manager">
                            </div>
                        </div>
                        <input type="hidden" name="targetUserId" value="@u?.Id">
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="sfSubmit">
                        <span id="sfSpinner" class="spinner-border spinner-border-sm me-1 d-none" role="status"></span>
                        Send to Salesforce
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Owned inventories table -->
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0"><i class="bi bi-boxes me-2 text-primary"></i>@Localizer["MyInventories"]</h5>
        @if (isMe)
        {
            <a asp-page="/Inventories/Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>@Localizer["New"]
            </a>
        }
    </div>

    @if (!Model.OwnedInvs.Any())
    {
        <p class="text-muted small">@Localizer["NoInventoriesYet"]</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>@Localizer["Title"]</th>
                        <th>@Localizer["Category"]</th>
                        <th class="text-center">@Localizer["Items"]</th>
                        <th>@Localizer["LastUpdated"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model.OwnedInvs)
                    {
                        <tr class="cursor-pointer"
                            onclick="location.href='@Url.Page("/Inventories/Detail", new { id = inv.Id })'">
                            <td class="fw-semibold">@inv.Title</td>
                            <td class="text-muted small">@(inv.Category ?? "—")</td>
                            <td class="text-center"><span class="badge bg-secondary">@inv.ItemCount</span></td>
                            <td class="text-muted small">@inv.UpdatedAt.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Write-access inventories table -->
<div>
    <h5 class="mb-2"><i class="bi bi-pencil-square me-2 text-success"></i>@Localizer["InventoriesWithWriteAccess"]</h5>
    @if (!Model.AccessInvs.Any())
    {
        <p class="text-muted small">@Localizer["NoWriteAccessGrants"]</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>@Localizer["Title"]</th>
                        <th>@Localizer["Category"]</th>
                        <th class="text-center">@Localizer["Items"]</th>
                        <th>@Localizer["LastUpdated"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model.AccessInvs)
                    {
                        <tr class="cursor-pointer"
                            onclick="location.href='@Url.Page("/Inventories/Detail", new { id = inv.Id })'">
                            <td class="fw-semibold">@inv.Title</td>
                            <td class="text-muted small">@(inv.Category ?? "—")</td>
                            <td class="text-center"><span class="badge bg-secondary">@inv.ItemCount</span></td>
                            <td class="text-muted small">@inv.UpdatedAt.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <style>.cursor-pointer { cursor: pointer; }</style>

    @if (isMe || User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value is not null)
    {
        <script>
        // Pre-fill contact fields from the user's profile
        (function () {
            var fullName = '@Html.Raw(u?.Name?.Replace("'", "\\'") ?? "")';
            var email    = '@Html.Raw(u?.Email?.Replace("'", "\\'") ?? "")';
            var parts    = fullName.trim().split(/\s+/);
            var first    = parts.length > 1 ? parts.slice(0, -1).join(' ') : '';
            var last     = parts[parts.length - 1] || fullName;

            var elFirst = document.getElementById('sfFirstName');
            var elLast  = document.getElementById('sfLastName');
            var elEmail = document.getElementById('sfEmail');
            if (elFirst) elFirst.value = first;
            if (elLast)  elLast.value  = last;
            if (elEmail) elEmail.value  = email;
        })();

        document.getElementById('sfSubmit')?.addEventListener('click', async function () {
            const form    = document.getElementById('sfForm');
            const alert   = document.getElementById('sfAlert');
            const spinner = document.getElementById('sfSpinner');
            const btn     = this;

            if (!form.reportValidity()) return;

            // Show loading state
            btn.disabled = true;
            spinner.classList.remove('d-none');
            alert.className = 'alert d-none';

            const data = new FormData(form);
            // attach CSRF token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (token) data.append('__RequestVerificationToken', token);

            try {
                const resp = await fetch('/Api/Salesforce', {
                    method: 'POST',
                    body: data,
                    headers: { 'RequestVerificationToken': token ?? '' }
                });
                const json = await resp.json();

                if (json.success) {
                    alert.className = 'alert alert-success';
                    alert.innerHTML = `
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <strong>Success!</strong> Created in Salesforce.<br>
                        Account ID: <code>${json.accountId}</code><br>
                        Contact ID: <code>${json.contactId}</code>`;
                } else {
                    alert.className = 'alert alert-danger';
                    alert.innerHTML = `<i class="bi bi-exclamation-triangle-fill me-2"></i>${json.error}`;
                }
            } catch (e) {
                alert.className = 'alert alert-danger';
                alert.textContent = 'Network error: ' + e.message;
            } finally {
                btn.disabled = false;
                spinner.classList.add('d-none');
            }
        });
        </script>
    }
}